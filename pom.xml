<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>gottsch</groupId>
    <artifactId>howlman</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <!-- Fallbacks; overridden automatically by the platform-detection profiles below -->
        <javafx.platform>win</javafx.platform>
        <jpackage.type>app-image</jpackage.type>
        <jpackage.icon.file>icon.png</jpackage.icon.file>
    </properties>

    <dependencies>
        <!-- JavaFX (compile scope; excluded from CLI fat jar by shade filter) -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>21</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>21</version>
        </dependency>

        <!-- CLI framework -->
        <dependency>
            <groupId>info.picocli</groupId>
            <artifactId>picocli</artifactId>
            <version>4.7.5</version>
        </dependency>

        <!-- JSON -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.20.0</version>
        </dependency>

        <!-- Testing -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.10.2</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <version>5.11.0</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <version>5.11.0</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>true</filtering>
                <includes>
                    <include>**/*.properties</include>
                </includes>
            </resource>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>false</filtering>
                <excludes>
                    <exclude>**/*.properties</exclude>
                </excludes>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.2</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <finalName>howlman-1.0.0</finalName>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>gottschlinger.howlman.HowlMan</mainClass>
                                </transformer>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                                <!-- keep JavaFX out of the CLI fat jar -->
                                <filter>
                                    <artifact>org.openjfx:*</artifact>
                                    <excludes>
                                        <exclude>**</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!--
            gui profile — adds platform-native JavaFX jars and build tooling.
            The correct classifier (win / mac / mac-aarch64 / linux) is selected
            automatically by the platform-detection profiles below.

            Development run:  javafx:run  (from IntelliJ Maven panel)
            Build installer:  mvn -P gui verify -DskipTests
              Windows → target/dist/HowlMan-1.0.0.exe  (requires WiX v3)
              Mac     → target/dist/HowlMan-1.0.0.dmg  (change type to dmg)
        -->
        <profile>
            <id>gui</id>
            <dependencies>
                <dependency>
                    <groupId>org.openjfx</groupId>
                    <artifactId>javafx-base</artifactId>
                    <version>21</version>
                    <classifier>${javafx.platform}</classifier>
                </dependency>
                <dependency>
                    <groupId>org.openjfx</groupId>
                    <artifactId>javafx-graphics</artifactId>
                    <version>21</version>
                    <classifier>${javafx.platform}</classifier>
                </dependency>
                <dependency>
                    <groupId>org.openjfx</groupId>
                    <artifactId>javafx-controls</artifactId>
                    <version>21</version>
                    <classifier>${javafx.platform}</classifier>
                </dependency>
                <dependency>
                    <groupId>org.openjfx</groupId>
                    <artifactId>javafx-fxml</artifactId>
                    <version>21</version>
                    <classifier>${javafx.platform}</classifier>
                </dependency>
            </dependencies>
            <build>
                <plugins>

                    <!-- Development launcher: javafx:run from Maven panel -->
                    <plugin>
                        <groupId>org.openjfx</groupId>
                        <artifactId>javafx-maven-plugin</artifactId>
                        <version>0.0.8</version>
                        <configuration>
                            <mainClass>gottschlinger.howlman.gui.GuiLauncher</mainClass>
                            <options>
                                <option>--enable-native-access=ALL-UNNAMED</option>
                            </options>
                        </configuration>
                    </plugin>

                    <!-- Step 1 (verify): copy platform JavaFX jars into app-input alongside the main jar -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-dependency-plugin</artifactId>
                        <version>3.6.0</version>
                        <executions>
                            <execution>
                                <id>copy-javafx-mods</id>
                                <phase>verify</phase>
                                <goals><goal>copy</goal></goals>
                                <configuration>
                                    <artifactItems>
                                        <artifactItem>
                                            <groupId>org.openjfx</groupId>
                                            <artifactId>javafx-base</artifactId>
                                            <version>21</version>
                                            <classifier>${javafx.platform}</classifier>
                                        </artifactItem>
                                        <artifactItem>
                                            <groupId>org.openjfx</groupId>
                                            <artifactId>javafx-graphics</artifactId>
                                            <version>21</version>
                                            <classifier>${javafx.platform}</classifier>
                                        </artifactItem>
                                        <artifactItem>
                                            <groupId>org.openjfx</groupId>
                                            <artifactId>javafx-controls</artifactId>
                                            <version>21</version>
                                            <classifier>${javafx.platform}</classifier>
                                        </artifactItem>
                                        <artifactItem>
                                            <groupId>org.openjfx</groupId>
                                            <artifactId>javafx-fxml</artifactId>
                                            <version>21</version>
                                            <classifier>${javafx.platform}</classifier>
                                        </artifactItem>
                                    </artifactItems>
                                    <outputDirectory>${project.build.directory}/app-input</outputDirectory>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                    <!-- Step 2 (verify): stage app jar and clean previous dist -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-antrun-plugin</artifactId>
                        <version>3.1.0</version>
                        <executions>
                            <execution>
                                <id>stage-app-jar</id>
                                <phase>verify</phase>
                                <goals><goal>run</goal></goals>
                                <configuration>
                                    <target>
                                        <delete dir="${project.build.directory}/dist"/>
                                        <copy file="${project.build.directory}/howlman-1.0.0.jar"
                                              todir="${project.build.directory}/app-input"/>
                                        <copy file="${project.basedir}/src/main/resources/gottschlinger/howlman/gui/${jpackage.icon.file}"
                                              todir="${project.build.directory}/app-input"/>
                                    </target>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                    <!-- Step 3 (verify): build self-contained app image via jpackage.
                         JavaFX jars sit alongside the main jar in app-input so that
                         $APPDIR (resolved at launch) points to all required modules. -->
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.1.0</version>
                        <executions>
                            <execution>
                                <id>jpackage</id>
                                <phase>verify</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <executable>${java.home}/bin/jpackage</executable>
                                    <workingDirectory>${project.basedir}</workingDirectory>
                                    <arguments>
                                        <argument>--type</argument>
                                        <argument>${jpackage.type}</argument>
                                        <argument>--name</argument>
                                        <argument>HowlMan</argument>
                                        <argument>--app-version</argument>
                                        <argument>1.0.0</argument>
                                        <argument>--input</argument>
                                        <argument>${project.build.directory}/app-input</argument>
                                        <argument>--main-jar</argument>
                                        <argument>howlman-1.0.0.jar</argument>
                                        <argument>--main-class</argument>
                                        <argument>gottschlinger.howlman.gui.GuiLauncher</argument>
                                        <argument>--java-options</argument>
                                        <argument>--module-path $APPDIR</argument>
                                        <argument>--java-options</argument>
                                        <argument>--add-modules javafx.controls,javafx.fxml,javafx.graphics,javafx.base</argument>
                                        <argument>--java-options</argument>
                                        <argument>--enable-native-access=ALL-UNNAMED</argument>
                                        <argument>--icon</argument>
                                        <argument>${project.build.directory}/app-input/${jpackage.icon.file}</argument>
                                        <argument>--dest</argument>
                                        <argument>${project.build.directory}/dist</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                </plugins>
            </build>
        </profile>
        <!--
            OS-detection profiles — auto-activate to set javafx.platform.
            The gui profile's classifier picks this up automatically.
        -->
        <profile>
            <id>platform-win</id>
            <activation>
                <os><family>windows</family></os>
            </activation>
            <properties>
                <javafx.platform>win</javafx.platform>
                <jpackage.type>app-image</jpackage.type>
                <jpackage.icon.file>icon.ico</jpackage.icon.file>
            </properties>
        </profile>

        <profile>
            <id>platform-mac</id>
            <activation>
                <os>
                    <family>mac</family>
                    <arch>x86_64</arch>
                </os>
            </activation>
            <properties>
                <javafx.platform>mac</javafx.platform>
                <jpackage.type>app-image</jpackage.type>
                <jpackage.icon.file>icon.icns</jpackage.icon.file>
            </properties>
        </profile>

        <profile>
            <id>platform-mac-aarch64</id>
            <activation>
                <os>
                    <family>mac</family>
                    <arch>aarch64</arch>
                </os>
            </activation>
            <properties>
                <javafx.platform>mac-aarch64</javafx.platform>
                <jpackage.type>app-image</jpackage.type>
                <jpackage.icon.file>icon.icns</jpackage.icon.file>
            </properties>
        </profile>

        <profile>
            <id>platform-linux</id>
            <activation>
                <os><name>Linux</name></os>
            </activation>
            <properties>
                <javafx.platform>linux</javafx.platform>
                <jpackage.type>app-image</jpackage.type>
                <jpackage.icon.file>icon.png</jpackage.icon.file>
            </properties>
        </profile>

    </profiles>

</project>
