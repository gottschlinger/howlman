<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<SplitPane orientation="VERTICAL" dividerPositions="0.55"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gottschlinger.howlman.gui.controller.RequestTabController">

    <!-- REQUEST EDITOR -->
    <VBox styleClass="request-pane" minHeight="220">
        <!-- Breadcrumb: collection / request-name -->
        <HBox styleClass="request-title-bar" alignment="CENTER_LEFT" spacing="4">
            <padding><Insets top="5" right="10" bottom="5" left="12"/></padding>
            <Label fx:id="collectionBreadcrumb" styleClass="breadcrumb-new" text="New Request"/>
            <Label fx:id="breadcrumbSep" text=" / " styleClass="breadcrumb-sep"
                   visible="false" managed="false"/>
            <Label fx:id="requestBreadcrumb" styleClass="breadcrumb-request"
                   visible="false" managed="false"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- URL bar -->
        <HBox styleClass="url-bar" spacing="8" alignment="CENTER">
            <padding><Insets top="8" right="10" bottom="8" left="10"/></padding>
            <ComboBox fx:id="methodCombo" prefWidth="110"/>
            <TextField fx:id="urlField" HBox.hgrow="ALWAYS"
                       promptText="Enter URL  (supports {{variables}})"/>
            <Button fx:id="copyUrlButton" text="" onAction="#onCopyUrl"
                    styleClass="small-button" minWidth="28" maxWidth="28"/>
            <Button fx:id="sendButton" text="Send" onAction="#onSend" styleClass="send-button"/>
            <Button text="Save" onAction="#onSave" styleClass="save-button"/>
            <Button text="Save As…" onAction="#onSaveAs" styleClass="save-button"/>
        </HBox>

        <!-- Request tabs: Auth | Headers | Body -->
        <TabPane fx:id="requestTabs" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

            <!-- AUTH tab -->
            <Tab text="Auth">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Auth type:"/>
                        <ComboBox fx:id="authTypeCombo" prefWidth="130"
                                  onAction="#onAuthTypeChanged"/>
                    </HBox>

                    <!-- Bearer token fields -->
                    <GridPane fx:id="bearerPane" hgap="10" vgap="8"
                              visible="false" managed="false">
                        <columnConstraints>
                            <ColumnConstraints minWidth="90" prefWidth="90"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="Token:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="tokenField" GridPane.columnIndex="1"
                                   GridPane.rowIndex="0" promptText="Bearer token"/>
                    </GridPane>

                    <!-- Basic auth fields -->
                    <GridPane fx:id="basicPane" hgap="10" vgap="8"
                              visible="false" managed="false">
                        <columnConstraints>
                            <ColumnConstraints minWidth="90" prefWidth="90"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="usernameField" GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>
                        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <PasswordField fx:id="passwordField" GridPane.columnIndex="1"
                                       GridPane.rowIndex="1"/>
                    </GridPane>
                </VBox>
            </Tab>

            <!-- HEADERS tab -->
            <Tab text="Headers">
                <VBox>
                    <TableView fx:id="headersTable" VBox.vgrow="ALWAYS" editable="true">
                        <columns>
                            <TableColumn fx:id="headerKeyCol" text="Key" prefWidth="220"/>
                            <TableColumn fx:id="headerValueCol" text="Value" prefWidth="440"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    <HBox spacing="6" style="-fx-padding: 4 6 4 6;">
                        <Button text="+ Add" onAction="#onAddHeader" styleClass="small-button"/>
                        <Button text="Remove" onAction="#onRemoveHeader" styleClass="small-button"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- BODY tab -->
            <Tab text="Body">
                <VBox spacing="6">
                    <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Body type:"/>
                        <ComboBox fx:id="bodyTypeCombo" prefWidth="120"/>
                    </HBox>
                    <TextArea fx:id="bodyArea" VBox.vgrow="ALWAYS"
                              promptText="Request body" wrapText="false"
                              styleClass="mono-area"/>
                </VBox>
            </Tab>

            <!-- PRE tab -->
            <Tab text="Pre">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <CheckBox fx:id="preEnabledCheck"
                                  text="Run on send"
                                  onAction="#onPreEnabledChanged"/>
                    </HBox>
                    <TableView fx:id="preTable" VBox.vgrow="ALWAYS" editable="true">
                        <columns>
                            <TableColumn fx:id="preVarCol"       text="Environment Variable" prefWidth="200"/>
                            <TableColumn fx:id="preGeneratorCol" text="Generator"             prefWidth="160"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    <HBox spacing="6">
                        <Button text="+ Add"  onAction="#onAddPre"    styleClass="small-button"/>
                        <Button text="Remove" onAction="#onRemovePre" styleClass="small-button"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- POST tab -->
            <Tab text="Post">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <CheckBox fx:id="extractEnabledCheck"
                                  text="Extract on send"
                                  onAction="#onExtractEnabledChanged"/>
                    </HBox>
                    <TableView fx:id="extractTable" VBox.vgrow="ALWAYS" editable="true">
                        <columns>
                            <TableColumn fx:id="extractVarCol"  text="Environment Variable"  prefWidth="180"/>
                            <TableColumn fx:id="extractPathCol" text="JSON Path" prefWidth="340"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    <HBox spacing="6" style="-fx-padding: 0 0 0 0;">
                        <Button text="+ Add"  onAction="#onAddExtract"    styleClass="small-button"/>
                        <Button text="Remove" onAction="#onRemoveExtract" styleClass="small-button"/>
                    </HBox>
                </VBox>
            </Tab>

        </TabPane>
    </VBox>

    <!-- RESPONSE VIEWER -->
    <VBox styleClass="response-pane" minHeight="150">
        <HBox styleClass="response-header" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="6" right="10" bottom="6" left="10"/></padding>
            <Label text="Response" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" styleClass="status-label"/>
        </HBox>

        <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
            <Tab text="Body">
                <TextArea fx:id="responseBody" editable="false" wrapText="false"
                          styleClass="mono-area" promptText="Response will appear here"/>
            </Tab>
            <Tab text="Headers">
                <TableView fx:id="responseHeaders">
                    <columns>
                        <TableColumn fx:id="respHeaderKeyCol" text="Header" prefWidth="220"/>
                        <TableColumn fx:id="respHeaderValueCol" text="Value" prefWidth="440"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </Tab>
        </TabPane>
    </VBox>

</SplitPane>
