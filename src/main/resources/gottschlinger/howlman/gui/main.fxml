<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gottschlinger.howlman.gui.controller.MainController"
            prefWidth="1200" prefHeight="800">

    <!-- TOP: app toolbar -->
    <top>
        <ToolBar styleClass="top-bar">
            <Label text="HowlMan" styleClass="app-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Environment:"/>
            <ComboBox fx:id="environmentCombo" promptText="(none)" prefWidth="200"
                      onAction="#onEnvironmentChanged"/>
            <Button text="✎" onAction="#onRenameEnvironment" styleClass="icon-button"
                    fx:id="renameEnvButton">
                <tooltip><Tooltip text="Rename environment"/></tooltip>
            </Button>
            <Button text="+" onAction="#onNewEnvironment" styleClass="icon-button">
                <tooltip><Tooltip text="New environment"/></tooltip>
            </Button>
            <Button text="⚙" onAction="#onEditEnvironment" styleClass="icon-button"
                    fx:id="editEnvButton">
                <tooltip><Tooltip text="Edit variables"/></tooltip>
            </Button>
            <Button text="✕" onAction="#onDeleteEnvironment" styleClass="icon-button"
                    fx:id="deleteEnvButton">
                <tooltip><Tooltip text="Delete environment"/></tooltip>
            </Button>
            <Region prefWidth="12"/>
            <Button text="⚙ Settings" onAction="#onSettings" styleClass="settings-button">
                <tooltip><Tooltip text="Editor font settings"/></tooltip>
            </Button>
            <Button text="?" onAction="#onAbout" styleClass="icon-button">
                <tooltip><Tooltip text="About HowlMan"/></tooltip>
            </Button>
        </ToolBar>
    </top>

    <!-- CENTER: resizable sidebar + multi-tab request editor -->
    <center>
        <SplitPane dividerPositions="0.22">

            <!-- LEFT: collections sidebar -->
            <VBox styleClass="sidebar" minWidth="160">
                <HBox styleClass="sidebar-header" alignment="CENTER_LEFT" spacing="4">
                    <padding><Insets top="8" right="8" bottom="8" left="10"/></padding>
                    <Label text="Collections" styleClass="sidebar-title" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="importButton" text="" onAction="#onImportCollection" styleClass="icon-button">
                        <tooltip><Tooltip text="Import collection"/></tooltip>
                    </Button>
                    <Button fx:id="exportButton" text="" onAction="#onExportCollection" styleClass="icon-button">
                        <tooltip><Tooltip text="Export collection"/></tooltip>
                    </Button>
                    <Button text="+" onAction="#onNewCollection" styleClass="icon-button">
                        <tooltip><Tooltip text="New collection"/></tooltip>
                    </Button>
                </HBox>
                <TreeView fx:id="collectionTree" VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- RIGHT: tab pane -->
            <TabPane fx:id="requestTabPane" tabClosingPolicy="ALL_TABS"/>

        </SplitPane>
    </center>

</BorderPane>
